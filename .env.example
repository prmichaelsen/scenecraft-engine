# SceneCraft engine environment
# Copy to .env (gitignored) and fill in your values, then start the server:
#   .venv/bin/python -m scenecraft server
#
# Variables below are loaded from `.env` in the working directory OR
# ~/.config/scenecraft/.env (latter overrides former).

# ── Chat (Claude) ───────────────────────────────────────────────
# Required for /ws/chat/<project>. Claude Sonnet model used.
ANTHROPIC_API_KEY=

# ── OAuth (connects chat to external MCP servers via agentbase.me) ─
# Override if you run the server on a host/port other than localhost:8890.
# The redirect URI MUST be one of the registered URIs for the `scenecraft`
# client in agentbase.me's OAUTH_CLIENTS collection. Currently registered:
#   http://localhost:8890/oauth/callback
#   http://137.184.37.88:8890/oauth/callback
#   https://scenecraft.online/oauth/callback
SCENECRAFT_OAUTH_REDIRECT_URI=http://localhost:8890/oauth/callback

# OAuth authorization server — change only for staging/dev of agentbase.me.
#SCENECRAFT_AGENTBASE_URL=https://agentbase.me

# OAuth client ID registered with agentbase.me.
#SCENECRAFT_OAUTH_CLIENT_ID=scenecraft

# Remember MCP server endpoint (the resource server OAuth tokens authenticate to).
#SCENECRAFT_REMEMBER_MCP_URL=https://remember-mcp-server-dit6gawkbq-uc.a.run.app/mcp

# ── AI image/video providers (optional) ─────────────────────────
#GOOGLE_API_KEY=
#GOOGLE_CLOUD_PROJECT=
#REPLICATE_API_TOKEN=
#RUNWAY_API_KEY=
